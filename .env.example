# Optional. With NEITHER key set, /api/analyze-essay uses a built-in deterministic
# simulator so the prototype is fully interactive with zero configuration.

# Recommended: Anthropic (Claude). Used first if present.
# ANTHROPIC_API_KEY=sk-ant-...

# Alternative: OpenAI. Used if ANTHROPIC_API_KEY is absent.
# OPENAI_API_KEY=sk-...

# Optional: Tavus CVI — enables the face-to-face VIDEO mock interview in
# Interview Prep. All three are required for video; without them the tool still
# works in text mode. Create the persona + pick a replica in the Tavus
# dashboard, then paste the ids here.
# TAVUS_API_KEY=...
# TAVUS_REPLICA_ID=r...
# TAVUS_PERSONA_ID=p...

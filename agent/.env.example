# Top-level Spectrum credentials (from your Photon dashboard).
PROJECT_ID=
PROJECT_SECRET=

# Postgres connection used by the Drizzle-backed agent state store.
# Required for restart-safe onboarding memory, open loops, and profile updates.
DATABASE_URL=

# Comma-separated phone numbers or emails allowed to talk to the agent.
# Local iMessage often leaves message.sender empty; the allowlist also checks space.id.
# ALLOWED_SENDERS=+18015551234,+18015555678

# OpenAI-compatible LLM provider. Leave blank to use the deterministic scaffold.
# Example Kimi/Moonshot values:
# LLM_BASE_URL=https://api.moonshot.ai/v1
# LLM_MODEL=kimi-k2.6
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

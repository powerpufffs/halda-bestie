{
  "name": "halda-agent",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "start": "node --env-file=.env --import tsx src/index.ts",
    "start:cloud": "IMESSAGE_MODE=cloud node --env-file=.env --import tsx src/index.ts",
    "start:local": "IMESSAGE_MODE=local node --env-file=.env --import tsx src/index.ts",
    "start:terminal": "AGENT_TRANSPORT=terminal node --env-file=.env --import tsx src/index.ts",
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "dev:terminal": "AGENT_TRANSPORT=terminal node --env-file=.env --import tsx --watch src/index.ts",
    "import:scorecard": "node --env-file=.env --import tsx src/data/import-scorecard-institutions.ts",
    "import:scorecard:programs": "node --env-file=.env --import tsx src/data/import-scorecard-programs.ts",
    "test:communication-style": "node --import tsx src/demo/communication-style-smoke.ts",
    "test:onboarding": "node --import tsx src/demo/onboarding-smoke.ts",
    "test:reasoning-leak": "node --import tsx src/demo/reasoning-leak-smoke.ts",
    "test:visitor-handoff": "node --import tsx src/demo/visitor-handoff-smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "openai": "^6.44.0",
    "postgres": "^3.4.9",
    "spectrum-ts": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^22",
    "tsx": "^4"
  }
}

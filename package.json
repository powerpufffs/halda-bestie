{
  "name": "halda-bestie",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "app",
    "agent"
  ],
  "scripts": {
    "build:app": "bun run --cwd app build",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dev:agent": "bun run --cwd agent dev",
    "dev:agent:terminal": "bun run --cwd agent dev:terminal",
    "dev:app": "bun run --cwd app dev",
    "lint": "oxlint .",
    "lint:app": "bun run --cwd app lint",
    "import:scorecard": "bun run --cwd agent import:scorecard",
    "import:scorecard:programs": "bun run --cwd agent import:scorecard:programs",
    "repair:imessage-native": "npm rebuild better-sqlite3",
    "start:agent:terminal": "bun run --cwd agent start:terminal",
    "test:communication-style": "bun run --cwd agent test:communication-style",
    "test:onboarding": "bun run --cwd agent test:onboarding",
    "test:reasoning-leak": "bun run --cwd agent test:reasoning-leak",
    "test:visitor-handoff": "bun run --cwd agent test:visitor-handoff",
    "typecheck": "bun run --cwd app typecheck && bun run --cwd agent typecheck"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.70.0"
  },
  "trustedDependencies": [
    "better-sqlite3"
  ]
}
